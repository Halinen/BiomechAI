# 复制本文件为 .env，填入你的 API Key
# cp .env.example .env

# Groq API Key（当前默认 LLM 提供商，免费档 100k tokens/天）
# 在 https://console.groq.com/keys 申请
GROQ_API_KEY=gsk_你的_groq_key_写这里

# Anthropic API Key（可选 — 切到 Claude 时使用）
# 在 https://console.anthropic.com/ 申请
# ANTHROPIC_API_KEY=sk-ant-api03-你的密钥写这里

# Hugging Face Token（可选 — 下载 sentence-transformers 时避免限流）
# 在 https://huggingface.co/settings/tokens 申请
# HF_TOKEN=hf_你的_token_写这里
